# Copy this file to .env and fill values. Do NOT commit secrets.

# Keep paid subscriptions hidden while Scopey is in public beta.
# Set to true only when Pro/Business checkout is ready to sell.
PAID_PLANS_ENABLED=false

STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

STRIPE_PRICE_ID_PRO=price_xxx
STRIPE_PRICE_ID_BUSINESS=price_xxx
# Legacy fallback if you already created this before Business was named.
STRIPE_PRICE_ID_PRO_PLUS=price_xxx

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxx
SUPABASE_STORAGE_BUCKET=scopey-uploads

# Comma-separated Supabase account emails allowed to view admin launch readiness.
SCOPEY_ADMIN_EMAILS=you@example.com

# Optional: enables real branded email sending. Without this, Scopey opens a mailto draft.
RESEND_API_KEY=
EMAIL_FROM=Scopey <hello@example.com>

# Public frontend URL used for client links, email links, CORS and Stripe redirects.
FRONTEND_URL=https://www.scopey.co.uk
# Optional comma-separated extra origins, for preview deployments or a separate frontend host.
ADDITIONAL_CORS_ORIGINS=http://scopey.co.uk,https://www.scopey.co.uk,https://scopey.co.uk

# Backend port
PORT=3000
# Optional: API requests per 15 minutes per IP. Local testing can be chatty.
RATE_LIMIT_MAX=600
